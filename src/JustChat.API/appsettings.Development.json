{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "JwtOptions": {
    "Issuer": "local-auth-server",
    "Audience": "local-api",
    "ExpirationTimeInMinutes": 5
  },
  "RefreshTokenOptions": {
    "ExpirationTimeInDays": 7,
    "RotationThresholdDays": 1
  },
  "Frontend": {
    "Url": "http://localhost:4200"
  }
}
